# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric)
# To find your ID, message @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# Cursor API Key
# Get from Cursor settings > Account > API Key
CURSOR_API_KEY=your_cursor_api_key_here

# Path to the default project directory Cursor will operate in
# You can override this per-command or set it with /project command
# Example: /Users/admin/Projects/my-project
CURSOR_DEFAULT_PROJECT_DIR=/path/to/your/project

# (Deprecated: use CURSOR_DEFAULT_PROJECT_DIR instead)
# CURSOR_PROJECT_DIR=/path/to/your/project

# Default mode for file modifications (true/false)
# When true, /prompt will also allow file writes
CURSOR_FORCE_MODE=false
